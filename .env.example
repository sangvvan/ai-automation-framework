# ── Required ────────────────────────────────────────────────
NODE_ENV=development
DATABASE_URL=postgresql://app:app@localhost:5433/app_dev
# At least 32 chars. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-random-string-at-least-32-chars

# ── Web base URL (used by the Review UI) ─────────────────────
BASE_URL=http://localhost:3000

# ── AI provider routing (see configs/ai-provider.yaml) ───────
# Default is "mock" so the framework runs offline. Switch to "claude"
# (and supply CLAUDE_API_KEY) for real AI scenario generation.
AI_TEST_DEFAULT_PROVIDER=mock

# Optional provider credentials
# CLAUDE_API_KEY=
# CODEX_API_KEY=
# OPENCODE_API_URL=http://localhost:1234/v1

# ── CLI runtime overrides (override configs/framework.config.yaml) ─
# AI_TEST_BASE_URL=http://localhost:3000
# AI_TEST_REPORTS_DIR=reports
# AI_TEST_HEADLESS=true
# AI_TEST_WORKERS=1
# AI_TEST_MAX_SCENARIOS=25
