{
  "name": "ai-automation-framework",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "remix-serve ./build/server/index.js",
    "typecheck": "tsc",
    "db:migrate": "node --experimental-strip-types scripts/migrate.ts",
    "ai-test": "vite-node scripts/ai-test.ts",
    "fixture:serve": "node tests/fixtures/sample-app/server.mjs",
    "test": "vitest run",
    "test:framework-system": "vitest run --config vitest.system.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:system": "playwright test --config playwright.system.config.ts",
    "test:system:all": "playwright test --config playwright.system.config.ts --project=chromium --project=firefox --project=webkit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@remix-run/node": "^2.12.0",
    "@remix-run/react": "^2.12.0",
    "@remix-run/serve": "^2.12.0",
    "bcryptjs": "^2.4.3",
    "isbot": "^4.4.0",
    "jwt-decode": "^4.0.0",
    "pg": "^8.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.48.0",
    "@remix-run/dev": "^2.12.0",
    "@remix-run/eslint-config": "^2.17.4",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.0",
    "@types/pg": "^8.11.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.1",
    "happy-dom": "^20.9.0",
    "msw": "^2.4.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.22.1",
    "typescript": "^5.5.4",
    "vite": "^5.3.5",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^4.1.5"
  }
}
